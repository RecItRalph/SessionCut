{
  "name": "SessionCut",
  "version": "1.0.2",
  "description": "An AI-powered auto-editor to automatically trim silences.",
  "author": "Jonathan Hartwig",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "basic-ftp": "^5.2.0",
    "chokidar": "^3.6.0",
    "electron-updater": "^6.1.8",
    "electron-window-state": "^5.0.3",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "fluent-ffmpeg": "^2.1.2",
    "onnxruntime-node": "^1.25.1"
  },
  "build": {
    "appId": "com.sessioncut.app",
    "productName": "SessionCut",
    "publish": {
      "provider": "github",
      "owner": "streamboss",
      "repo": "SessionCut"
    },
    "files": [
      "**/*",
      "!**/*.py",
      "!build_env",
      "!build_env/**/*",
      "!dist",
      "!dist/**/*",
      "!src",
      "!*.md",
      "!.github/**",
      "!bin/**",
      "!models/**",
      "!scratch/**",
      "!scratch.js",
      "!**/node_modules/*/{CHANGELOG.md,README.md,README,readme.md}",
      "!**/node_modules/*/{test,__tests__,tests,powered-test,example,examples}",
      "!**/node_modules/*.d.ts",
      "!**/node_modules/.bin"
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.video",
      "hardenedRuntime": false,
      "icon": "assets/SessionCutIcon.icns",
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "extraResources": [
        {
          "from": "assets/silero_vad.onnx",
          "to": "silero_vad.onnx"
        },
        {
          "from": "node_modules/ffmpeg-static/ffmpeg",
          "to": "ffmpeg"
        },
        {
          "from": "node_modules/ffprobe-static/bin/darwin/x64/ffprobe",
          "to": "ffprobe"
        },
        {
          "from": "bin/",
          "to": "bin"
        }
      ]
    },
    "win": {
      "target": "nsis",
      "icon": "assets/SessionCutLogoSquare.png",
      "extraResources": [
        {
          "from": "assets/silero_vad.onnx",
          "to": "silero_vad.onnx"
        },
        {
          "from": "node_modules/ffmpeg-static/ffmpeg.exe",
          "to": "ffmpeg.exe"
        },
        {
          "from": "node_modules/ffprobe-static/bin/win32/x64/ffprobe.exe",
          "to": "ffprobe.exe"
        },
        {
          "from": "bin/",
          "to": "bin"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "SessionCut"
    },
    "fileAssociations": [
      {
        "ext": [
          "mp4",
          "mov",
          "mkv",
          "mp3",
          "wav"
        ],
        "name": "Media File",
        "description": "Media file for SessionCut",
        "role": "Editor"
      }
    ]
  }
}
