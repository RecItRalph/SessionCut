{
  "name": "SessionCut",
  "version": "1.0.0",
  "description": "An AI-powered auto-editor to automatically trim silences.",
  "author": "Jonathan Hartwig",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "basic-ftp": "^5.2.0",
    "chokidar": "^3.6.0",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "fluent-ffmpeg": "^2.1.2",
    "electron-updater": "^6.1.8"
  },
  "build": {
    "appId": "com.sessioncut.app",
    "productName": "SessionCut",
    "publish": {
      "provider": "github",
      "owner": "streamboss",
      "repo": "SessionCut"
    },
    "files": [
      "**/*",
      "!**/*.py",
      "!build_env",
      "!build_env/**/*",
      "!dist",
      "!dist/**/*",
      "!src",
      "!*.md",
      "!**/node_modules/*/{CHANGELOG.md,README.md,README,readme.md}",
      "!**/node_modules/*/{test,__tests__,tests,powered-test,example,examples}",
      "!**/node_modules/*.d.ts",
      "!**/node_modules/.bin"
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.video",
      "hardenedRuntime": false,
      "icon": "assets/SessionCutIcon.icns"
    },
    "fileAssociations": [
      {
        "ext": [
          "mp4",
          "mov",
          "mkv"
        ],
        "name": "Video File",
        "description": "Video file for SessionCut",
        "role": "Editor"
      }
    ],
    "extraResources": [
      {
        "from": "dist/vad",
        "to": "vad"
      },
      {
        "from": "assets/silero_vad.jit",
        "to": "silero_vad.jit"
      },
      {
        "from": "node_modules/ffmpeg-static/ffmpeg",
        "to": "ffmpeg"
      },
      {
        "from": "node_modules/ffprobe-static/bin/darwin/x64/ffprobe",
        "to": "ffprobe"
      }
    ]
  }
}
